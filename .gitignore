# ====================================
# 르니브 ERP — Git Ignore
# 비밀 정보 및 개인정보 포함 파일은 절대 커밋 금지
# ====================================

# -------- 비밀 정보 (API keys, webhooks, tokens) --------
coupang-credentials.txt
slack-webhook.txt
*credentials*
*secret*
*.key
*.env
.env.*

# -------- 고객 개인정보 포함 파일 --------
coupang-sample-order.json
coupang-test-response.json
erp-import-*.csv
orders-*.json
customers-*.json

# -------- Excel 임시 파일 --------
~$*.xlsx
~$*.xls
.~lock.*

# -------- OS / IDE --------
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# -------- 빌드 / 로그 --------
*.log
logs/
dist/
build/
node_modules/
__pycache__/
